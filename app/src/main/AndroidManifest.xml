<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      QUERY_ALL_PACKAGES: a notification-management app must enumerate every installed
      app so the user can choose which ones participate in the Digest. This is a
      Play-approved use case for this app category (the listener legitimately needs the
      full app list). Declared visibility alternatives cannot enumerate arbitrary apps.
    -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <!-- Required to post the digest summary notification on Android 13+. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Re-arm scheduled digests after a device reboot. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Gentle haptic feedback for delivery (optional, user-controllable). -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Google Drive backup: sign-in + Drive REST calls. The ONLY network the app makes; nothing
         else leaves the device. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".NotDigestApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:enableOnBackInvokedCallback="true"
        android:theme="@style/Theme.NotificationDigest"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.NotificationDigest.Splash"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
          The core of the product. The system binds this service to deliver every posted
          notification. We persist + suppress notifications from apps in Digest mode and
          leave Real-Time apps untouched.
        -->
        <service
            android:name=".service.DigestNotificationListenerService"
            android:exported="true"
            android:label="@string/notification_access_label"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
            <!--
              No default_filter_types: that would exclude SILENT notifications (the ones some OEMs
              like ColorOS show in a "Silent" tray). We want to capture every type.
            -->
        </service>

        <!-- Handles digest-notification action buttons (Deliver Now / Review / dismiss). -->
        <receiver
            android:name=".notification.NotificationActionReceiver"
            android:exported="false" />

        <!-- Re-schedules digests after reboot / app update. -->
        <receiver
            android:name=".work.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!--
          WorkManager is initialised on-demand through a Hilt-aware factory, so the
          default startup initializer is removed here.
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>

</manifest>
