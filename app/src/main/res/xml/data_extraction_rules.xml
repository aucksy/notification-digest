<?xml version="1.0" encoding="utf-8"?>
<!--
  Privacy by design (Android 12+). Declaring an <include> switches Auto Backup to "include-only"
  mode, so ONLY config_backup.json is backed up — app classifications, schedules and settings.
  The notifications database, DataStore preferences and everything else are excluded by default,
  so notification CONTENT never leaves the device.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="file" path="config_backup.json" />
    </cloud-backup>
    <device-transfer>
        <include domain="file" path="config_backup.json" />
    </device-transfer>
</data-extraction-rules>
