# Copy this file to `keystore.properties` (which is gitignored) and fill in your values.
# Used by app/build.gradle.kts to sign the release build locally.
#
# Generate a keystore first (keytool ships with any JDK, including JDK 8):
#   keytool -genkeypair -v -keystore release.keystore \
#     -alias notdigest -keyalg RSA -keysize 2048 -validity 10000
#
# `storeFile` is resolved relative to the `app/` module — use an absolute path,
# or place the keystore at the repo root and point to ../release.keystore

storeFile=../release.keystore
storePassword=CHANGE_ME
keyAlias=notdigest
keyPassword=CHANGE_ME
